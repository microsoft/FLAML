# Set the default repository for channels specified only by name.
# Conda will substitute ${ARTIFACTS_CONDA_TOKEN} with the environment variable of the same name.
channel_alias: https://token:${ARTIFACTS_CONDA_TOKEN}@msdata.pkgs.visualstudio.com/A365/_packaging/Synapse-Conda/Conda/repo/

# Override the default default_channels so that they use channel_alias.
# If default_channels is not specified here, Conda will use anaconda.com for these channels regardless of channel_alias or custom_channels.
default_channels:
  - pkgs/main
  - pkgs/r
  - pkgs/msys2

# Override the default for the pkgs/pro channel. Using null will cause Conda to use channel_alias.
custom_channels:
  pkgs/pro: null
